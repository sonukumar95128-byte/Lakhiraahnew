# Database (Hostinger MySQL — hPanel → Databases → MySQL Databases)
# Create a database + user there, then enable "Remote MySQL" and allow your connecting IP
# if connecting from outside Hostinger (e.g. local dev). Format below.
DATABASE_URL="mysql://user:password@host:3306/dbname"

# Auth (Auth.js / NextAuth) — generate with: npx auth secret
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Razorpay (https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# WhatsApp ordering fallback — used until Razorpay is live.
# Format: country code + number, no spaces or '+' (e.g. 919876543210)
NEXT_PUBLIC_WHATSAPP_BUSINESS_NUMBER="911234567890"

# Temporary admin panel password gate — replace with real auth (NextAuth) later.
ADMIN_PASSWORD="changeme123"

# Used for sitemap.xml and SEO metadata — set to your real production domain.
NEXT_PUBLIC_SITE_URL="https://lakshiraah.in"
